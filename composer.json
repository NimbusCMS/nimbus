{
    "name": "nimbuscms/nimbus",
    "description": "A lightweight, extensible PHP CMS: structured collections, a readable core, and Composer-based plugins.",
    "type": "project",
    "keywords": [
        "cms",
        "php",
        "headless",
        "collections",
        "plugins",
        "lightweight"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "DanMat"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nimbus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nimbus\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/nimbus"
    ],
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "smoke": "tests/smoke.sh",
        "check": [
            "@analyse",
            "@test"
        ],
        "serve": "php -S 0.0.0.0:8080 -t public public/index.php"
    },
    "config": {
        "sort-packages": true
    }
}

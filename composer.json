{
    "name": "danmat/nimbus-cms",
    "description": "NimbusCMS — a modern, lightweight PHP CMS: collections, media library, a headless JSON API, and a themeable admin + public site.",
    "type": "project",
    "keywords": ["cms", "php", "headless", "collections", "media-library", "lightweight"],
    "license": "MIT",
    "authors": [
        { "name": "DanMat" }
    ],
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "Nimbus\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Nimbus\\Tests\\": "tests/" }
    },
    "bin": ["bin/nimbus"],
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=512M",
        "check": [
            "@analyse",
            "@test"
        ],
        "serve": "php -S 0.0.0.0:8080 -t public public/index.php"
    },
    "config": {
        "sort-packages": true
    }
}
